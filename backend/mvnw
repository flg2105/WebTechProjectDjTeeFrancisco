#!/bin/sh
# Apache Maven Wrapper bootstrap (downloads wrapper jar if missing).
# Kept intentionally small; relies on the wrapper jar from Maven Central.

set -euf

MVNW_REPOURL="${MVNW_REPOURL:-https://repo.maven.apache.org/maven2}"
WRAPPER_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
MAVEN_PROJECTBASEDIR="$WRAPPER_DIR"
MAVEN_WRAPPER_JAR="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar"
MAVEN_WRAPPER_PROPERTIES="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.properties"

if [ ! -f "$MAVEN_WRAPPER_PROPERTIES" ]; then
  echo "Missing $MAVEN_WRAPPER_PROPERTIES" >&2
  exit 1
fi

if [ ! -f "$MAVEN_WRAPPER_JAR" ]; then
  WRAPPER_VERSION="3.3.2"
  WRAPPER_JAR_URL="$MVNW_REPOURL/org/apache/maven/wrapper/maven-wrapper/${WRAPPER_VERSION}/maven-wrapper-${WRAPPER_VERSION}.jar"
  mkdir -p "$(dirname "$MAVEN_WRAPPER_JAR")"

  if command -v curl >/dev/null 2>&1; then
    curl -fsSL "$WRAPPER_JAR_URL" -o "$MAVEN_WRAPPER_JAR"
  elif command -v wget >/dev/null 2>&1; then
    wget -q "$WRAPPER_JAR_URL" -O "$MAVEN_WRAPPER_JAR"
  else
    echo "Neither curl nor wget is available to download Maven wrapper jar." >&2
    exit 1
  fi
fi

exec java -classpath "$MAVEN_WRAPPER_JAR" org.apache.maven.wrapper.MavenWrapperMain -Dmaven.multiModuleProjectDirectory="$MAVEN_PROJECTBASEDIR" "$@"
