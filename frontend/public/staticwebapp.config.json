{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/assets/*",
      "/*.png",
      "/*.jpg",
      "/*.jpeg",
      "/*.svg",
      "/*.ico"
    ]
  },
  "routes": [
    {
      "route": "/*",
      "headers": {
        "Cache-Control": "no-store"
      }
    }
  ]
}
