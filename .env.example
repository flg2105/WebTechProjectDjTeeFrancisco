# Backend
# Note: Spring Boot does not automatically read the repo-root `.env` file.
# Use `scripts/dev-backend.sh` to load these variables before running the backend.
SPRING_PROFILES_ACTIVE=local

# CORS (frontend dev server)
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional: override datasource (useful when running `SPRING_PROFILES_ACTIVE=mysql`)
# SPRING_DATASOURCE_URL=jdbc:mysql://127.0.0.1:3306/project_pulse?sslMode=REQUIRED&allowPublicKeyRetrieval=true&serverTimezone=UTC
# SPRING_DATASOURCE_USERNAME=projectpulse
# SPRING_DATASOURCE_PASSWORD=projectpulse

# Frontend
# Note: Vite reads `VITE_*` variables from the shell.
# Use `scripts/dev-frontend.sh` to load these variables before running the frontend.
VITE_API_BASE_URL=http://localhost:8080
